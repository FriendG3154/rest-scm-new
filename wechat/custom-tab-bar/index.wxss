.tab-bar {
  display: flex;
  align-items: center;
  justify-content: space-around;
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  height: 120rpx;
  padding-bottom: env(safe-area-inset-bottom);
  background: rgba(255, 255, 255, 0.85);
  backdrop-filter: blur(40rpx);
  -webkit-backdrop-filter: blur(40rpx);
  border-top: 1rpx solid rgba(196, 198, 207, 0.2);
  z-index: 999;
}

.tab-bar-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  flex: 1;
  padding: 12rpx 0;
  color: #43474e;
  transition: all 0.2s ease;
}

.tab-bar-item.active {
  color: #002045;
}

.tab-icon-wrap {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 80rpx;
  height: 56rpx;
  border-radius: 24rpx;
  margin-bottom: 4rpx;
  transition: all 0.2s ease;
}

.tab-icon-active {
  background-color: #dee8ff;
}

.tab-label {
  font-size: 20rpx;
  font-weight: 600;
  letter-spacing: 1rpx;
}
