<view class="login-page">
  <!-- 背景装饰 -->
  <view class="bg-circle bg-circle-1"></view>
  <view class="bg-circle bg-circle-2"></view>

  <!-- 主体内容 -->
  <view class="login-content">
    <!-- App 标识 -->
    <view class="brand-section">
      <!-- <view class="brand-icon">
        <image src='../../img/logo.png' style='width: 144rpx;height: 124rpx;'></image>
      </view> -->
      <text class="brand-title">XX餐厅</text>
    </view>

    <!-- 登录表单 -->
    <view class="form-section">
      <!-- 手机号 -->
      <view class="input-group">
        <text class="input-label">手机号码登录</text>
        <view class="input-field {{phoneFocus ? 'input-focus' : ''}}">
          <t-icon name="mobile" size="40rpx" color="#43474e" />
          <input type="number" maxlength="11" placeholder="输入手机号" placeholder-class="input-placeholder" value="{{phone}}" bindinput="onPhoneInput" bindfocus="onPhoneFocus" bindblur="onPhoneBlur" />
        </view>
      </view>

      <!-- 密码 -->
      <view class="input-group">
        <text class="input-label">密码登录</text>
        <view class="input-field {{passwordFocus ? 'input-focus' : ''}}">
          <t-icon name="lock-on" size="40rpx" color="#43474e" />
          <input type="text" password="{{!showPassword}}" placeholder="输入密码" placeholder-class="input-placeholder" value="{{password}}" bindinput="onPasswordInput" bindfocus="onPasswordFocus" bindblur="onPasswordBlur" />
          <view class="password-toggle" bind:tap="togglePassword">
            <t-icon name="{{showPassword ? 'browse' : 'browse-off'}}" size="36rpx" color="#74777f" />
          </view>
        </view>
      </view>

      <!-- 登录按钮 -->
      <view class="login-btn-wrap">
        <t-button theme="primary" block size="large" loading="{{loading}}" bind:tap="handleLogin" class="login-btn">
          登录
        </t-button>
      </view>

      <!-- 分隔线 -->
      <view class="divider">
        <view class="divider-line"></view>
        <text class="divider-text">OR</text>
        <view class="divider-line"></view>
      </view>

      <!-- 微信手机号快捷登录 -->
      <button class="wechat-btn {{wechatLoading ? 'wechat-btn-loading' : ''}}" open-type="getPhoneNumber" bindgetphonenumber="getPhoneNumber">
        <t-loading wx:if="{{wechatLoading}}" size="40rpx" />
        <text class="wechat-text">{{wechatLoading ? '登录中...' : '微信一键登录'}}</text>
      </button>
    </view>

    <!-- 用户协议 -->
    <view class="agreement-section">
      <t-checkbox
        value="{{agreed}}"
        bind:change="onAgreeChange"
      />
      <text class="agreement-text">
        <text>我已阅读并同意</text>
        <text class="agreement-link" bind:tap="watchService">服务条款</text>
        <text>和</text>
        <text class="agreement-link">隐私政策</text>
      </text>
    </view>
  </view>

  <t-toast id="t-toast" />
</view>