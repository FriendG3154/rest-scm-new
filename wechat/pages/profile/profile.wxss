.profile-page {
  min-height: 100vh;
  background-color: #f9f9ff;
}

.nav-bar {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 100;
  background-color: rgba(249, 249, 255, 0.92);
  backdrop-filter: blur(40rpx);
}

.nav-bar-inner {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 16rpx 32rpx;
  height: 88rpx;
}

.nav-bar-left {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.nav-bar-title {
  font-size: 36rpx;
  color: #002045;
  letter-spacing: -1rpx;
}

.profile-content {
  padding: 48rpx 32rpx;
  padding-bottom: calc(env(safe-area-inset-bottom) + 140rpx);
}

/* 用户卡片 */
.profile-card {
  display: flex;
  align-items: center;
  gap: 32rpx;
  padding: 40rpx;
  background-color: #f0f3ff;
  border-radius: 32rpx;
  margin-bottom: 40rpx;
  position: relative;
}

.profile-avatar-wrap {
  position: relative;
  flex-shrink: 0;
}

.profile-avatar {
  width: 128rpx;
  height: 128rpx;
  border-radius: 50%;
  border: 6rpx solid #ffffff;
}

.profile-avatar-default {
  width: 128rpx;
  height: 128rpx;
  border-radius: 50%;
  border: 6rpx solid #ffffff;
  background-color: #dee8ff;
  display: flex;
  align-items: center;
  justify-content: center;
}

.verified-badge {
  position: absolute;
  bottom: 0;
  right: 0;
  background-color: #ffffff;
  border-radius: 50%;
  padding: 4rpx;
}

.profile-info {
  display: flex;
  flex-direction: column;
}

.profile-name {
  font-size: 40rpx;
  color: #002045;
  letter-spacing: -1rpx;
  margin-bottom: 4rpx;
}

.profile-role {
  font-size: 24rpx;
  color: #43474e;
  font-weight: 500;
}

/* 菜单区域 */
.menu-section {
  margin-bottom: 32rpx;
}

.menu-header {
  padding: 0 8rpx;
  margin-bottom: 12rpx;
}

.menu-header-text {
  font-size: 22rpx;
  font-weight: 700;
  color: #43474e;
  letter-spacing: 2rpx;
  text-transform: uppercase;
}

.menu-list {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.menu-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 28rpx;
  background-color: #ffffff;
  border-radius: 20rpx;
  border: 1rpx solid rgba(196, 198, 207, 0.1);
}

.menu-item-left {
  display: flex;
  align-items: center;
  gap: 16rpx;
  flex: 1;
  min-width: 0;
}

.menu-item-info {
  display: flex;
  flex-direction: column;
  min-width: 0;
}

.menu-item-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #002045;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.menu-item-sub {
  font-size: 20rpx;
  color: rgba(67, 71, 78, 0.7);
  margin-top: 2rpx;
}

.menu-item-badge {
  background-color: #dee8ff;
  padding: 4rpx 16rpx;
  border-radius: 999rpx;
}

.menu-item-badge-text {
  font-size: 20rpx;
  font-weight: 600;
  color: #002045;
}

/* 退出登录 */
.logout-wrap {
  margin-top: 24rpx;
}

.logout-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  width: calc(100% - 56rpx);
  padding: 28rpx;
  background-color: #dee8ff;
  border-radius: 20rpx;
  transition: all 0.2s;
}

.logout-btn:active {
  background-color: #ffdad6;
  transform: scale(0.98);
}

.logout-text {
  font-size: 28rpx;
  font-weight: 700;
  color: #ba1a1a;
}

/* 品牌标识 */
.brand-footer {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding-top: 80rpx;
}

.brand-footer-text {
  font-size: 18rpx;
  font-weight: 800;
  color: rgba(0, 32, 69, 0.15);
  letter-spacing: 4rpx;
  margin-top: 12rpx;
}
